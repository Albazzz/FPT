# Copy to .env for local vercel dev — DO NOT commit .env
# Neon pooler connection string
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Master Control code (also default in api if env empty)
MASTER_CODE=Namcong9@

# Optional: separate signing secret
SESSION_SECRET=Namcong9@-session

# Optional: comma-separated allowed origins, or * 
CORS_ORIGIN=*

# Session lifetime in days
SESSION_TTL_DAYS=90
